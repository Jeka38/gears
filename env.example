# ───────────────────────────────────────────────────────────────
# Настройки XMPP (Jabber) аккаунта бота
# ───────────────────────────────────────────────────────────────

# Полный JID бота (Jabber ID) — обязательно с доменом
XMPP_JID=bot-files@example.com

# Ресурс JID (опционально)
XMPP_RESOURCE=bot

# Пароль от этого Jabber-аккаунта
XMPP_PASSWORD=SuperSecretPassw0rd

# Хост XMPP-сервера (можно указать IP, но лучше домен)
XMPP_HOST=example.com

# Порт XMPP-сервера (обычно 5222 для обычного соединения, 5223 для старого SSL)
XMPP_PORT=5222

# JID администратора (для уведомлений и управления)
ADMIN_JID=admin@example.com

# Путь к JSON-файлу белого списка
WHITELIST_FILE=whitelist.json

# Версия приложения (опционально)
APP_VERSION=1.1

# Название приложения (опционально)
APP_NAME=OBBFastBot


# ───────────────────────────────────────────────────────────────
# Настройки веб-отдачи файлов
# ───────────────────────────────────────────────────────────────

# Базовый публичный URL, по которому будут доступны файлы
# Важно: без завершающего слеша
BASE_URL=https://files.yourdomain.com

# Порт, на котором будет слушать nginx ВНУТРИ контейнера
# Обычно оставляют 80 или 443, т.к. внешний порт маппится в docker-compose
WEB_PORT=443


# ───────────────────────────────────────────────────────────────
# Файловая система и квота
# ───────────────────────────────────────────────────────────────

# Путь внутри контейнера, куда бот сохраняет файлы
# Должен совпадать с тем, что указано в docker-compose volumes
DOWNLOAD_DIR=/app/downloads

# Максимальный объём файлов на одного пользователя (в гигабайтах)
QUOTA_GB=2


# ───────────────────────────────────────────────────────────────
# Пути к SSL-сертификатам ВНУТРИ контейнера nginx
# Эти пути должны совпадать с тем, что монтируется в docker-compose
# ───────────────────────────────────────────────────────────────

# Путь к файлу полного сертификата (fullchain.pem от Let's Encrypt / Certbot)
SSL_CERT_PATH=/app/cert/fullchain.pem

# Путь к приватному ключу (privkey.pem)
SSL_KEY_PATH=/app/cert/privkey.pem

# Порт для встроенного HTTP Upload сервера (XEP-0363)
HTTP_UPLOAD_PORT=8080
