# ───────────────────────────────────────────────────────────────
# Базовый образ — обычно лучше брать с тегом, чтобы избежать сюрпризов
# Рекомендую: python:3.11-slim  или python:3.12-slim-bookworm
# ───────────────────────────────────────────────────────────────
FROM python:3.12-slim

# ───────────────────────────────────────────────────────────────
# Рабочая директория внутри контейнера
# Все последующие команды COPY, RUN, CMD будут выполняться относительно /app
# ───────────────────────────────────────────────────────────────
WORKDIR /app

# ───────────────────────────────────────────────────────────────
# Копируем и устанавливаем зависимости ПЕРВЫМИ — это главный приём для кэширования слоёв
# ───────────────────────────────────────────────────────────────

# Копируем только requirements.txt (он редко меняется)
COPY requirements.txt .

# Устанавливаем Python-пакеты
# --no-cache-dir = не сохраняем кэш pip → уменьшаем размер образа
RUN pip install --no-cache-dir -r requirements.txt

# ───────────────────────────────────────────────────────────────
# Копируем весь остальной код проекта
# Этот слой будет пересобираться при любом изменении в коде
# ───────────────────────────────────────────────────────────────
COPY . .

# ───────────────────────────────────────────────────────────────
# Команда, которая запускается при старте контейнера
# В твоём коде основной файл называется main.py (а не bot.py и не app.py)
# ───────────────────────────────────────────────────────────────
CMD ["python", "main.py"]
